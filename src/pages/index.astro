---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import WhyCopyCodeAI from '../components/WhyCopyCodeAI.astro';
import EntryOffer from '../components/EntryOffer.astro';
import SelectedWork from '../components/SelectedWork.astro';
import FastLaunchEngineering from '../components/FastLaunchEngineering.astro';
import HowItWorks from '../components/HowItWorks.astro';
import MiniScenarios from '../components/MiniScenarios.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Launch engineering for European startups | CopyCodeAI"
  description="Launch engineering for early-stage European startups: MVPs, landing pages, AI features, and GDPR/EAA-aware implementation support."
  canonical="https://copycodeai.online/"
  includeOfferSync={true}
>
  <Navbar active="home" />

  <main id="main-content" tabindex="-1">
    <Hero />
    <WhyCopyCodeAI />
    <EntryOffer />
    <SelectedWork />
    <FastLaunchEngineering />
    <HowItWorks />
    <MiniScenarios />
  </main>

  <Footer />
</BaseLayout>
