---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
import CTAGroup from '../components/layout/CTAGroup.astro';

const asciiCat = String.raw` /\_/\\
( o.o )
 > ^ <`;
---

<BaseLayout
  title="Page not found | CopyCodeAI"
  description="The page you’re looking for may have moved or may belong to an older version of the site."
  robots="noindex, follow"
>
  <Navbar />

  <main id="main-content" tabindex="-1">
    <Section variant="compact" aria-labelledby="not-found-title">
      <Container size="content">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">404</p>
        <h1 id="not-found-title" class="mt-2 text-4xl font-bold text-ink-900 sm:text-5xl">Page not found</h1>
        <p class="mt-4 max-w-3xl text-lg text-slate-700">Sorry — this page may have been eaten by the cat.</p>
        <p class="mt-3 max-w-3xl text-sm text-slate-600">
          It may be an old link from a previous version of the site, or the page may have moved.
        </p>

        <pre class="mt-6 inline-block rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm leading-5 text-slate-700 shadow-soft" aria-label="Cat illustration">{asciiCat}</pre>

        <CTAGroup class="mt-6">
          <a
            href="/"
            class="inline-flex items-center justify-center rounded-xl bg-brand-700 px-6 py-3 text-sm font-semibold text-white shadow-soft hover:bg-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
          >
            Go to Home
          </a>
          <a
            href="/guides/"
            class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 hover:border-slate-400 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
          >
            Browse Guides
          </a>
          <a
            href="/services"
            class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 hover:border-slate-400 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
          >
            View Services
          </a>
        </CTAGroup>
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
