---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/layout/Section.astro';
import Container from '../../components/layout/Container.astro';

function isSafeGuideReturnPath(value: string | null): value is `/guides/${string}/` | `/guides/${string}` {
  return typeof value === 'string' && /^\/guides\/[a-z0-9-]+\/?$/.test(value);
}

const searchParams = Astro.url.searchParams;
const returnTo = isSafeGuideReturnPath(searchParams.get('returnTo')) ? searchParams.get('returnTo') : '/guides/';
const resource = searchParams.get('resource') === 'checklist' ? 'checklist' : 'guide';
const resourceLabel = resource === 'checklist' ? 'checklist' : 'guide';

const pageTitle = 'Access link unavailable | CopyCodeAI';
const pageDescription = 'This access link is missing, invalid, or expired. Request a new copy to continue.';
const pageCanonical = 'https://copycodeai.online/guides/access-link-unavailable/';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={pageCanonical}
  robots="noindex, nofollow"
  ogTitle={pageTitle}
  ogDescription={pageDescription}
>
  <Navbar active="guides" />

  <main id="main-content" tabindex="-1">
    <Section variant="compact" aria-labelledby="access-page-title">
      <Container size="content">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">Guides</p>
        <h1 id="access-page-title" class="mt-2 text-4xl font-bold text-ink-900 sm:text-5xl">
          Access link unavailable
        </h1>
        <p class="mt-4 max-w-3xl text-lg text-slate-700">
          This link is missing, invalid, or expired.
        </p>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-700">
          Request a new copy by email to access the {resourceLabel} again.
        </p>
      </Container>
    </Section>

    <Section aria-labelledby="request-link-title">
      <Container size="content">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700">Request a new access link</p>
          <h2 id="request-link-title" class="mt-2 text-3xl font-semibold text-ink-900">
            Get back to the full {resourceLabel}
          </h2>
          <p class="mt-3 max-w-2xl text-base leading-7 text-slate-700">
            We’ll send a fresh link to the public request page, so you can open the current version of the {resourceLabel} again.
          </p>

          <div class="mt-6">
            <a
              href={returnTo}
              class="inline-flex items-center justify-center rounded-xl bg-brand-700 px-5 py-3 text-sm font-semibold text-white hover:bg-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
            >
              Request a new access link
            </a>
          </div>

          <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-5">
            <p class="text-sm font-semibold text-ink-900">Need a different page?</p>
            <p class="mt-2 text-sm leading-6 text-slate-700">
              If you opened this page by mistake, go back to the <a href="/guides/" class="font-medium text-brand-700 hover:text-brand-800">Guides</a> listing and choose the right resource.
            </p>
          </div>
        </div>
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
