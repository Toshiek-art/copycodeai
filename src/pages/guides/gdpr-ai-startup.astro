---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/layout/Section.astro';
import Container from '../../components/layout/Container.astro';
import GuideHeader from '../../components/guides/GuideHeader.astro';
import GuideCTA from '../../components/guides/GuideCTA.astro';
import GuideRelatedService from '../../components/guides/GuideRelatedService.astro';
import GuideRelatedGuides from '../../components/guides/GuideRelatedGuides.astro';
import GuideDownloadForm from '../../components/forms/GuideDownloadForm.astro';
import GuideRequestFeedback from '../../components/guides/GuideRequestFeedback.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { getGuideBySlug, getRelatedGuides } from '../../data/guides';
import { getGuideDownloadBySlug } from '../../data/guide-downloads';

const requestPreviewPoints = [
  {
    title: 'Where data enters',
    body: 'Prompts, uploads, forms, and backend handoff points all count. If the path is fuzzy, the risk is already there.'
  },
  {
    title: 'Who owns the flow',
    body: 'A launch owner should be able to say who decides the purpose, the legal basis, and the review path.'
  },
  {
    title: 'What the model provider sees',
    body: 'Check the vendor boundary, logging, retention, and any reuse before the feature becomes normal.'
  },
  {
    title: 'When to pause',
    body: 'If the feature starts profiling, handling sensitive data, or mixing sources, stop and confirm whether a DPIA review is needed.'
  }
];

const guide = getGuideBySlug('gdpr-ai-startup');
const guideDownload = getGuideDownloadBySlug('gdpr-ai-startup');

if (!guide) {
  throw new Error('Guide metadata not found for gdpr-ai-startup');
}

if (!guideDownload) {
  throw new Error('Guide download metadata not found for gdpr-ai-startup');
}

const pageTitle = `${guide.title} | CopyCodeAI`;
const breadcrumbs = [
  { label: 'Guides', href: '/guides/' },
  { label: guide.title }
];
const relatedGuides = getRelatedGuides('gdpr-ai-startup').map(({ category, title, description, href }) => ({
  category,
  title,
  description,
  href
}));

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.title,
  description: guide.description,
  datePublished: guide.publishAt,
  dateModified: guide.updatedAt,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': guide.canonical
  },
  url: guide.canonical,
  articleSection: guide.category,
  author: {
    '@type': 'Organization',
    name: 'CopyCodeAI'
  },
  publisher: {
    '@type': 'Organization',
    name: 'CopyCodeAI'
  }
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Guides',
      item: 'https://copycodeai.online/guides/'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: guide.title,
      item: guide.canonical
    }
  ]
};
---

<BaseLayout
  title={pageTitle}
  description={guide.description}
  canonical={guide.canonical}
  ogTitle={pageTitle}
  ogDescription={guide.description}
>
  <Navbar active="guides" />

  <JsonLd data={articleJsonLd} />
  <JsonLd data={breadcrumbJsonLd} />

  <main id="main-content" tabindex="-1">
    <Section variant="compact">
      <Container size="content">
        <GuideHeader
          category={guide.category}
          title={guide.title}
          description={guide.description}
          publishAt={guide.publishAt}
          updatedAt={guide.updatedAt}
          breadcrumbs={breadcrumbs}
        />
      </Container>
    </Section>

    <Section aria-labelledby="request-preview-title">
      <Container size="content">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700">Preview</p>
          <h2 id="request-preview-title" class="mt-2 text-3xl font-semibold text-ink-900">
            What this guide helps you decide before launch
          </h2>
          <p class="mt-4 max-w-3xl text-base leading-7 text-slate-700">
            This is a flow-first guide for AI startups and digital businesses that need to understand where data enters, who controls it, and which decisions should be made before the product gets harder to change.
          </p>

          <div class="mt-6 grid gap-4 lg:grid-cols-2">
            {requestPreviewPoints.map((point) => (
              <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-soft">
                <h3 class="text-lg font-semibold text-ink-900">{point.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-700">{point.body}</p>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </Section>

    <Section aria-labelledby="request-guide-title">
      <Container size="content">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-soft">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700">Get it by email</p>
          <h2 id="request-guide-title" class="mt-2 text-3xl font-semibold text-ink-900">Get the full guide by email</h2>
          <p class="mt-3 max-w-3xl text-base leading-7 text-slate-700">
            Leave your email and we’ll send the full guide link. It’s a practical reference for the team when the feature is still easy to change.
          </p>

          <div class="mt-6" data-guide-request-form-wrapper>
            <GuideDownloadForm guideSlug={guide.slug} returnTo={guideDownload.returnTo} />
          </div>

          <GuideRequestFeedback />
        </div>
      </Container>
    </Section>

    <Section>
      <Container size="content">
        <GuideRelatedService
          title="Related service"
          label={guide.relatedService.label}
          href={guide.relatedService.href}
        />
      </Container>
    </Section>

    <Section>
      <Container size="content">
        <GuideRelatedGuides guides={relatedGuides} title="Related guides" />
      </Container>
    </Section>

    <Section variant="compact">
      <Container size="content">
        <GuideCTA
          eyebrow="Next step"
          title="If the feature already touches real data, map it before the next release."
          description="A structured pre-launch blueprint or audit helps turn unclear processing into decisions the team can keep using as the product grows."
          primaryLabel="View Blueprint"
          primaryHref="/#blueprint"
          secondaryLabel="See Services"
          secondaryHref="/services"
        />
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
