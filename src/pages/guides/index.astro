---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/layout/Section.astro';
import Container from '../../components/layout/Container.astro';
import CTAGroup from '../../components/layout/CTAGroup.astro';
import GuideCard from '../../components/guides/GuideCard.astro';
import { getPublishedGuides } from '../../data/guides';

const guides = getPublishedGuides();

const coverPoints = [
  'AI feature implementation risk',
  'GDPR-ready data flow',
  'EAA / accessibility structure',
  'Launch decisions that reduce rework'
];
---

<BaseLayout
  title="Guides for launch risk and implementation | CopyCodeAI"
  description="Practical guides for startups and digital businesses shipping websites, forms, booking flows, ecommerce journeys, AI features, and compliance-sensitive product changes."
  canonical="https://copycodeai.online/guides/"
  ogTitle="Guides for launch risk and implementation | CopyCodeAI"
  ogDescription="Practical guides for startups and digital businesses shipping websites, forms, booking flows, ecommerce journeys, AI features, and compliance-sensitive product changes."
>
  <Navbar active="guides" />

  <main id="main-content" tabindex="-1">
    <Section variant="compact" aria-labelledby="guides-page-title">
      <Container size="content">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">Guides</p>
        <h1 id="guides-page-title" class="mt-2 text-4xl font-bold text-ink-900 sm:text-5xl">
          Practical guidance for launch risk, implementation, and compliance-aware product work.
        </h1>
        <p class="mt-4 max-w-3xl text-lg text-slate-700">
          These guides help founders and product teams ship websites, forms, booking and contact flows, ecommerce journeys, AI features, and other product changes without introducing avoidable compliance debt, accessibility gaps, or structural rework.
        </p>
        <p class="mt-3 max-w-3xl text-sm text-slate-600">
          Focused on implementation choices. Technical guidance only, not legal advice.
        </p>
        <div class="mt-5 flex flex-wrap gap-2 text-xs font-medium text-slate-700">
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1">Launch risk and implementation notes</span>
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1">AI, GDPR, accessibility</span>
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1">Editorial and practical</span>
        </div>
      </Container>
    </Section>

    <Section variant="muted" aria-labelledby="featured-guides-title">
      <Container size="content">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">Featured guides</p>
          <h2 id="featured-guides-title" class="mt-2 text-3xl font-semibold text-ink-900">Start here if you are planning a launch, a rebuild, or a product flow that needs clearer decisions.</h2>
          <p class="mt-3 text-slate-700">
            Each guide focuses on one decision area so teams can move from general intent to implementation shape without turning the project into a vague strategy exercise.
          </p>
        </div>

        <div class="mt-8 grid gap-6 lg:grid-cols-3 lg:gap-8">
          {guides.map((guide) => (
            <GuideCard
              category={guide.category}
              title={guide.title}
              description={guide.description}
              href={guide.href}
            />
          ))}
        </div>
      </Container>
    </Section>

    <Section aria-labelledby="what-guides-cover-title">
      <Container size="content">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">What these guides cover</p>
          <h2 id="what-guides-cover-title" class="mt-2 text-3xl font-semibold text-ink-900">The parts of a launch that usually create hidden work later.</h2>
          <p class="mt-3 text-slate-700">
            The focus is on structural decisions that affect the product after launch, not on high-level positioning advice.
          </p>

          <ul class="mt-6 grid gap-3 sm:grid-cols-2">
            {coverPoints.map((point) => (
              <li class="flex items-start gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
                <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-700 text-[11px] font-semibold leading-none text-white">✓</span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
      </Container>
    </Section>

    <Section variant="compact" aria-labelledby="guides-cta-title">
      <Container size="content">
        <div class="rounded-2xl border border-slate-200 bg-slate-900 p-6 text-slate-100 shadow-soft sm:p-8 lg:p-10">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-emerald-300">Next step</p>
          <h2 id="guides-cta-title" class="mt-2 text-3xl font-semibold text-white">If you want direct support, turn the guide into a scoped build plan.</h2>
          <p class="mt-3 max-w-3xl text-slate-300">
            The Blueprint / audit-style offer is the next step for teams that want decisions written down, risks called out, and implementation scope made explicit before build work starts.
          </p>
          <p class="mt-3 text-sm text-slate-300">
            You can also go straight to the services overview if you want to compare delivery options.
          </p>

          <CTAGroup>
            <a
              href="/#blueprint"
              class="inline-flex items-center justify-center rounded-xl bg-brand-700 px-5 py-3 text-sm font-semibold text-white hover:bg-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-900"
            >
              View Blueprint
            </a>
            <a
              href="/services"
              class="inline-flex items-center justify-center rounded-xl border border-slate-600 bg-transparent px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-900"
            >
              See Services
            </a>
          </CTAGroup>
        </div>
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
