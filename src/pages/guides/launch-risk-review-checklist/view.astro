---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import Section from '../../../components/layout/Section.astro';
import Container from '../../../components/layout/Container.astro';
import GuideHeader from '../../../components/guides/GuideHeader.astro';
import GuideRelatedService from '../../../components/guides/GuideRelatedService.astro';
import GuideRelatedGuides from '../../../components/guides/GuideRelatedGuides.astro';
import JsonLd from '../../../components/seo/JsonLd.astro';
import { getGuideBySlug, getRelatedGuides } from '../../../data/guides';

const checklistGroups = [
  {
    title: 'Changed journeys and release boundary',
    items: [
      'Name the exact journey being changed and the live path it affects.',
      'Confirm whether the change touches a form, booking, payment, contact, signup, or account path.',
      'Blocker: if the team cannot describe the live path end to end in one sentence.',
      'Evidence: a short note showing the before/after route or the exact flow under review.',
      'If the change introduces a new step, confirm who owns that step and who approves it.'
    ]
  },
  {
    title: 'Data capture at touchpoints',
    items: [
      'List every place data enters the flow: fields, prompts, uploads, hidden fields, embedded inputs, or API calls.',
      'Confirm what each touchpoint collects, why it exists, and what breaks if it is removed.',
      'Blocker: if any personal data enters without a named owner or a clear purpose.',
      'If the flow includes booking, checkout, or account creation, verify the minimum data needed is actually minimum.',
      'Evidence: test submission, captured payload, or screenshot showing what was really sent.'
    ]
  },
  {
    title: 'Consent, tracking, and third-party behavior',
    items: [
      'Separate required operational consent from optional marketing consent. The flow must still work when marketing is off.',
      'Verify that tracking, tags, and pixels match the actual consent state.',
      'Blocker: if tracking starts before consent or if a vendor fires on a state it should not see.',
      'If an embed, scheduler, payment tool, or analytics tool is present, confirm what it sees and when it fires.',
      'Evidence: tag preview, network capture, or live-mode proof from the browser.'
    ]
  },
  {
    title: 'Downstream flow, storage, and automation',
    items: [
      'Trace where the submission goes after it leaves the page: inbox, CRM, webhook, sheet, support queue, or automation.',
      'Confirm the destination is named, reachable, and reviewed.',
      'Blocker: if the downstream destination is unknown, shared too broadly, or silently duplicated.',
      'Check event order where it matters: user confirmation, webhook, CRM write, notification, and any follow-up action.',
      'If AI or automation is involved, confirm what input it receives, what output it can trigger, and who can stop it if it fails.',
      'Evidence: email receipt, CRM record, webhook event, log entry, or named automation owner.'
    ]
  },
  {
    title: 'Accessibility on critical journeys',
    items: [
      'Test the primary path with keyboard only.',
      'Verify labels, hints, errors, and success states are understandable without color alone.',
      'Blocker: if the user can reach the form but cannot complete it or recover from an error.',
      'If the flow spans multiple steps, verify users are not forced to re-enter information already provided unless there is a real operational reason.',
      'If the flow requires sign-in, a code, or a repeat visit, test timeout, retry, and resume behavior.',
      'If booking, payment, or checkout is part of the flow, verify focus order, field recovery, and duplicate-submit handling.',
      'Evidence: screenshot or short test note from a keyboard pass.'
    ]
  },
  {
    title: 'Release control, evidence, and rollback',
    items: [
      'Decide what blocks launch now and what can wait.',
      'Name the owner who signs off on the flow and the evidence they reviewed.',
      'Confirm the rollback or disable method for the risky part of the change.',
      'Blocker: if the change cannot be reversed fast enough to protect the launch.',
      'Verify that the live version and the tested version are the same one.',
      'Evidence: go/no-go note, owner name, and rollback method written down.'
    ]
  }
];

function splitLabeledCheck(item) {
  if (item.startsWith('Blocker:')) {
    return {
      label: 'Blocker',
      text: item.slice('Blocker:'.length).trim(),
      className: 'border-rose-200 bg-rose-50 text-rose-800'
    };
  }

  if (item.startsWith('Evidence:')) {
    return {
      label: 'Evidence',
      text: item.slice('Evidence:'.length).trim(),
      className: 'border-sky-200 bg-sky-50 text-sky-800'
    };
  }

  if (item.startsWith('Later:')) {
    return {
      label: 'Later',
      text: item.slice('Later:'.length).trim(),
      className: 'border-amber-200 bg-amber-50 text-amber-800'
    };
  }

  return null;
}

const guide = getGuideBySlug('launch-risk-review-checklist');

if (!guide) {
  throw new Error('Guide metadata not found for launch-risk-review-checklist');
}

const viewPath = 'https://copycodeai.online/guides/launch-risk-review-checklist/view/';
const pageTitle = `${guide.title} | CopyCodeAI`;
const breadcrumbs = [
  { label: 'Guides', href: '/guides/' },
  { label: guide.title }
];
const relatedGuides = getRelatedGuides('launch-risk-review-checklist').map(({ category, title, description, href }) => ({
  category,
  title,
  description,
  href
}));

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.title,
  description: guide.description,
  datePublished: guide.publishAt,
  dateModified: guide.updatedAt,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': viewPath
  },
  url: viewPath,
  articleSection: guide.category,
  author: {
    '@type': 'Organization',
    name: 'CopyCodeAI'
  },
  publisher: {
    '@type': 'Organization',
    name: 'CopyCodeAI'
  }
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Guides',
      item: 'https://copycodeai.online/guides/'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: guide.title,
      item: viewPath
    }
  ]
};
---

<BaseLayout
  title={pageTitle}
  description={guide.description}
  canonical={viewPath}
  ogTitle={pageTitle}
  ogDescription={guide.description}
>
  <Navbar active="guides" />

  <JsonLd data={articleJsonLd} />
  <JsonLd data={breadcrumbJsonLd} />

  <main id="main-content" tabindex="-1">
    <Section variant="compact">
      <Container size="content">
        <GuideHeader
          category={guide.category}
          title={guide.title}
          description={guide.description}
          publishAt={guide.publishAt}
          updatedAt={guide.updatedAt}
          breadcrumbs={breadcrumbs}
        />
      </Container>
    </Section>

    <Section aria-labelledby="article-content-title">
      <Container size="content">
        <article class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:text-ink-900 prose-p:leading-7 prose-li:leading-7 prose-a:font-medium prose-a:text-brand-700 prose-a:no-underline hover:prose-a:text-brand-800">
          <h2 id="article-content-title" class="sr-only">Article content</h2>

          <section aria-labelledby="why-title" class="not-prose">
            <h2 id="why-title" class="text-3xl font-semibold text-ink-900">Why this checklist exists</h2>
            <div class="mt-4 space-y-4 text-base leading-7 text-slate-700">
              <p>This is a flow-first launch risk review. It catches completion failures, avoidable compliance debt, and release blockers before they become expensive.</p>
              <p>Use it for websites, forms, booking or contact flows, ecommerce paths, accessibility-sensitive journeys, and conditional AI or automation touchpoints where relevant.</p>
              <p>When the path, data, or handoff changes, review it here before go-live.</p>
            </div>
          </section>

          <section aria-labelledby="checklist-title" class="not-prose mt-12">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700">Checklist</p>
              <h2 id="checklist-title" class="mt-2 text-3xl font-semibold text-ink-900">What to review before go-live</h2>

              <div class="mt-6 grid gap-4 lg:grid-cols-2">
                {checklistGroups.map((group) => (
                  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
                    <h3 class="text-lg font-semibold text-ink-900">{group.title}</h3>
                    <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-700">
                      {group.items.map((item) => {
                        const labelInfo = splitLabeledCheck(item);

                        return (
                          <li class="flex items-start gap-3">
                            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-500" aria-hidden="true"></span>
                            {labelInfo ? (
                              <span class="min-w-0">
                                <span class={`mb-1 inline-flex rounded-full border px-2 py-0.5 text-[11px] font-semibold uppercase tracking-[0.16em] ${labelInfo.className}`.trim()}>
                                  {labelInfo.label}
                                </span>
                                <span class="block">{labelInfo.text}</span>
                              </span>
                            ) : (
                              <span class="min-w-0">{item}</span>
                            )}
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section aria-labelledby="when-to-stop-title" class="not-prose mt-12">
            <div class="rounded-2xl border border-brand-200 bg-brand-50 p-6 sm:p-8">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700">If several items are unclear</p>
              <h2 id="when-to-stop-title" class="mt-2 text-3xl font-semibold text-ink-900">Stop and map the flow before the next release.</h2>
              <p class="mt-3 max-w-3xl text-base leading-7 text-slate-700">
                If the same issue appears in forms, tracking, booking, or access paths, the problem is usually structural. Write down the risks, order them by impact, and fix the blockers first.
              </p>
            </div>
          </section>
        </article>
      </Container>
    </Section>

    <Section>
      <Container size="content">
        <GuideRelatedService
          title="Related service"
          label={guide.relatedService.label}
          href={guide.relatedService.href}
        />
      </Container>
    </Section>

    <Section>
      <Container size="content">
        <GuideRelatedGuides guides={relatedGuides} title="Related guides" />
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
