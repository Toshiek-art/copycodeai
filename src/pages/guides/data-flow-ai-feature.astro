---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/layout/Section.astro';
import Container from '../../components/layout/Container.astro';
import GuideHeader from '../../components/guides/GuideHeader.astro';
import GuideCTA from '../../components/guides/GuideCTA.astro';
import GuideRelatedService from '../../components/guides/GuideRelatedService.astro';
import GuideRelatedGuides from '../../components/guides/GuideRelatedGuides.astro';
import GuideRequestPanel from '../../components/guides/GuideRequestPanel.astro';
import GuideDownloadForm from '../../components/forms/GuideDownloadForm.astro';
import GuideRequestFeedback from '../../components/guides/GuideRequestFeedback.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { getGuideBySlug, getRelatedGuides } from '../../data/guides';
import { getGuideDownloadBySlug } from '../../data/guide-downloads';

const requestPreviewPoints = [
  {
    title: 'Input to output',
    body: 'Know where the flow starts, where it hands off, and where the response comes back.'
  },
  {
    title: 'Boundary to provider',
    body: 'Check what leaves your system, which vendor sees it, and what it is allowed to keep.'
  },
  {
    title: 'Logging and reuse',
    body: 'If logs, retries, or debug copies exist, they need a reason and an owner.'
  },
  {
    title: 'Stop the launch',
    body: 'If the team cannot explain the path clearly, someone should be able to pause it.'
  }
];

const guide = getGuideBySlug('data-flow-ai-feature');
const guideDownload = getGuideDownloadBySlug('data-flow-ai-feature');

if (!guide) {
  throw new Error('Guide metadata not found for data-flow-ai-feature');
}

if (!guideDownload) {
  throw new Error('Guide download metadata not found for data-flow-ai-feature');
}

const pageTitle = `${guide.title} | CopyCodeAI`;
const breadcrumbs = [
  { label: 'Guides', href: '/guides/' },
  { label: guide.title }
];
const relatedGuides = getRelatedGuides('data-flow-ai-feature').map(({ category, title, description, href }) => ({
  category,
  title,
  description,
  href
}));

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.title,
  description: guide.description,
  datePublished: guide.publishAt,
  dateModified: guide.updatedAt,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': guide.canonical
  },
  url: guide.canonical,
  articleSection: guide.category,
  author: {
    '@type': 'Organization',
    name: 'CopyCodeAI'
  },
  publisher: {
    '@type': 'Organization',
    name: 'CopyCodeAI'
  }
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Guides',
      item: 'https://copycodeai.online/guides/'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: guide.title,
      item: guide.canonical
    }
  ]
};
---

<BaseLayout
  title={pageTitle}
  description={guide.description}
  canonical={guide.canonical}
  ogTitle={pageTitle}
  ogDescription={guide.description}
>
  <Navbar active="guides" />

  <JsonLd data={articleJsonLd} />
  <JsonLd data={breadcrumbJsonLd} />

  <main id="main-content" tabindex="-1">
    <Section variant="compact">
      <Container size="content">
        <GuideHeader
          category={guide.category}
          title={guide.title}
          description={guide.description}
          publishAt={guide.publishAt}
          updatedAt={guide.updatedAt}
          breadcrumbs={breadcrumbs}
        />
      </Container>
    </Section>

    <Section aria-labelledby="request-preview-title">
      <Container size="content">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700">Preview</p>
          <h2 id="request-preview-title" class="mt-2 text-3xl font-semibold text-ink-900">
            What this guide helps you map before shipping an AI feature
          </h2>
          <p class="mt-4 max-w-3xl text-base leading-7 text-slate-700">
            This is a flow-first pass for AI-assisted features where input, handoff, logging, and reuse can quietly become hard to explain once the product starts moving.
          </p>

          <div class="mt-6 grid gap-4 lg:grid-cols-2">
            {requestPreviewPoints.map((point) => (
              <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-soft">
                <h3 class="text-lg font-semibold text-ink-900">{point.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-700">{point.body}</p>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </Section>

    <Section id="guide-request" aria-labelledby="request-guide-title">
      <Container size="content">
        <GuideRequestPanel
          titleId="request-guide-title"
          eyebrowDefault="Get it by email"
          eyebrowRenew="Request a fresh access link"
          titleDefault="Get the full guide by email"
          titleRenew="Request a fresh access link by email"
          bodyDefault="Leave your email and we’ll send the full guide link. Use it when the feature is already wired into real data and you need a clearer map of the flow."
          bodyRenew="You’re returning from an expired or invalid access link. Use this form to request a fresh signed access link by email."
          submitRenew="Request a fresh access link"
        >
          <div class="mt-6" data-guide-request-form-wrapper>
            <GuideDownloadForm guideSlug={guide.slug} returnTo={guideDownload.returnTo} />
          </div>

          <GuideRequestFeedback />
        </GuideRequestPanel>
      </Container>
    </Section>

    <Section>
      <Container size="content">
        <GuideRelatedService
          title="Related service"
          label={guide.relatedService.label}
          href={guide.relatedService.href}
        />
      </Container>
    </Section>

    <Section>
      <Container size="content">
        <GuideRelatedGuides guides={relatedGuides} title="Related guides" />
      </Container>
    </Section>

    <Section variant="compact">
      <Container size="content">
        <GuideCTA
          eyebrow="Next step"
          title="If the data path is already spreading, map it before the next release."
          description="A structured pre-launch blueprint or audit helps turn unclear data handling into a system the team can still reason about as the feature grows."
          primaryLabel="View Blueprint"
          primaryHref="/#blueprint"
          secondaryLabel="See Services"
          secondaryHref="/services"
        />
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
