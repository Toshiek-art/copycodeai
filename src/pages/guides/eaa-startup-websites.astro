---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/layout/Section.astro';
import Container from '../../components/layout/Container.astro';
import GuideHeader from '../../components/guides/GuideHeader.astro';
import GuideCTA from '../../components/guides/GuideCTA.astro';
import GuideRelatedService from '../../components/guides/GuideRelatedService.astro';
import GuideRelatedGuides from '../../components/guides/GuideRelatedGuides.astro';
import GuideDownloadForm from '../../components/forms/GuideDownloadForm.astro';
import GuideRequestFeedback from '../../components/guides/GuideRequestFeedback.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { getGuideBySlug, getRelatedGuides } from '../../data/guides';
import { getGuideDownloadBySlug } from '../../data/guide-downloads';

const requestPreviewPoints = [
  {
    title: 'Navigation and hierarchy',
    body: 'Check whether the structure is stable enough that a user does not need to relearn it from page to page.'
  },
  {
    title: 'Forms and recovery',
    body: 'Labels, hints, errors, and repeat-entry behavior should help the user finish the task, not trap them.'
  },
  {
    title: 'Keyboard and focus',
    body: 'A keyboard user should be able to move through the flow without guessing where focus went.'
  },
  {
    title: 'Fix now vs later',
    body: 'Structural issues that affect completion belong before launch. Pure visual tweaks can usually wait.'
  }
];

const guide = getGuideBySlug('eaa-startup-websites');
const guideDownload = getGuideDownloadBySlug('eaa-startup-websites');

if (!guide) {
  throw new Error('Guide metadata not found for eaa-startup-websites');
}

if (!guideDownload) {
  throw new Error('Guide download metadata not found for eaa-startup-websites');
}

const pageTitle = `${guide.title} | CopyCodeAI`;
const breadcrumbs = [
  { label: 'Guides', href: '/guides/' },
  { label: guide.title }
];
const relatedGuides = getRelatedGuides('eaa-startup-websites').map(({ category, title, description, href }) => ({
  category,
  title,
  description,
  href
}));

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.title,
  description: guide.description,
  datePublished: guide.publishAt,
  dateModified: guide.updatedAt,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': guide.canonical
  },
  url: guide.canonical,
  articleSection: guide.category,
  author: {
    '@type': 'Organization',
    name: 'CopyCodeAI'
  },
  publisher: {
    '@type': 'Organization',
    name: 'CopyCodeAI'
  }
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Guides',
      item: 'https://copycodeai.online/guides/'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: guide.title,
      item: guide.canonical
    }
  ]
};
---

<BaseLayout
  title={pageTitle}
  description={guide.description}
  canonical={guide.canonical}
  ogTitle={pageTitle}
  ogDescription={guide.description}
>
  <Navbar active="guides" />

  <JsonLd data={articleJsonLd} />
  <JsonLd data={breadcrumbJsonLd} />

  <main id="main-content" tabindex="-1">
    <Section variant="compact">
      <Container size="content">
        <GuideHeader
          category={guide.category}
          title={guide.title}
          description={guide.description}
          publishAt={guide.publishAt}
          updatedAt={guide.updatedAt}
          breadcrumbs={breadcrumbs}
        />
      </Container>
    </Section>

    <Section aria-labelledby="request-preview-title">
      <Container size="content">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700">Preview</p>
          <h2 id="request-preview-title" class="mt-2 text-3xl font-semibold text-ink-900">
            What this guide helps you verify before launch
          </h2>
          <p class="mt-4 max-w-3xl text-base leading-7 text-slate-700">
            This is a structural pass for startup websites and digital products that need to stay usable, understandable, and stable when real users start moving through the flow.
          </p>

          <div class="mt-6 grid gap-4 lg:grid-cols-2">
            {requestPreviewPoints.map((point) => (
              <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-soft">
                <h3 class="text-lg font-semibold text-ink-900">{point.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-700">{point.body}</p>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </Section>

    <Section aria-labelledby="request-guide-title">
      <Container size="content">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 shadow-soft">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700">Get the guide</p>
          <h2 id="request-guide-title" class="mt-2 text-3xl font-semibold text-ink-900">Request a downloadable copy</h2>
          <p class="mt-3 max-w-3xl text-base leading-7 text-slate-700">
            Leave your email and we’ll send the full guide link. It’s useful when you want a practical read on what should be fixed now versus later.
          </p>

          <div class="mt-6" data-guide-request-form-wrapper>
            <GuideDownloadForm guideSlug={guide.slug} returnTo={guideDownload.returnTo} />
          </div>

          <GuideRequestFeedback />
        </div>
      </Container>
    </Section>

    <Section>
      <Container size="content">
        <GuideRelatedService
          title="Related service"
          label={guide.relatedService.label}
          href={guide.relatedService.href}
        />
      </Container>
    </Section>

    <Section>
      <Container size="content">
        <GuideRelatedGuides guides={relatedGuides} title="Related guides" />
      </Container>
    </Section>

    <Section variant="compact">
      <Container size="content">
        <GuideCTA
          eyebrow="Next step"
          title="If the structure is already fighting you, make the next release easier to maintain."
          description="A structured pre-launch blueprint or audit helps turn unclear page behavior into a plan the team can keep using as the product grows."
          primaryLabel="View Blueprint"
          primaryHref="/#blueprint"
          secondaryLabel="See Services"
          secondaryHref="/services"
        />
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
