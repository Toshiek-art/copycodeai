---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/layout/Section.astro';
import Container from '../../components/layout/Container.astro';
import GuideHeader from '../../components/guides/GuideHeader.astro';
import GuideRelatedService from '../../components/guides/GuideRelatedService.astro';
import GuideRelatedGuides from '../../components/guides/GuideRelatedGuides.astro';
import GuideEmailForm from '../../components/forms/GuideEmailForm.astro';
import FormStatus from '../../components/forms/FormStatus.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { getGuideBySlug, getRelatedGuides } from '../../data/guides';

const requestPreviewPoints = [
  {
    title: 'Changed journey',
    body: 'Name the live path, the release boundary, and the owner.'
  },
  {
    title: 'Data entry points',
    body: 'List every place data enters and what breaks if it is removed.'
  },
  {
    title: 'Consent and tracking',
    body: 'Separate operational consent from marketing consent before launch.'
  },
  {
    title: 'Downstream handoff',
    body: 'Trace where the submission goes and who can stop it.'
  },
  {
    title: 'Critical accessibility',
    body: 'Check completion, recovery, and repeat-entry friction on the live path.'
  },
  {
    title: 'Rollback control',
    body: 'Confirm evidence, sign-off, and a fast disable path.'
  }
];

const guide = getGuideBySlug('launch-risk-review-checklist');

if (!guide) {
  throw new Error('Guide metadata not found for launch-risk-review-checklist');
}

const pageTitle = `${guide.title} | CopyCodeAI`;
const breadcrumbs = [
  { label: 'Guides', href: '/guides/' },
  { label: guide.title }
];
const relatedGuides = getRelatedGuides('launch-risk-review-checklist').map(({ category, title, description, href }) => ({
  category,
  title,
  description,
  href
}));

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.title,
  description: guide.description,
  datePublished: guide.publishAt,
  dateModified: guide.updatedAt,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': guide.canonical
  },
  url: guide.canonical,
  articleSection: guide.category,
  author: {
    '@type': 'Organization',
    name: 'CopyCodeAI'
  },
  publisher: {
    '@type': 'Organization',
    name: 'CopyCodeAI'
  }
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Guides',
      item: 'https://copycodeai.online/guides/'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: guide.title,
      item: guide.canonical
    }
  ]
};
---

<BaseLayout
  title={pageTitle}
  description={guide.description}
  canonical={guide.canonical}
  ogTitle={pageTitle}
  ogDescription={guide.description}
>
  <Navbar active="guides" />

  <JsonLd data={articleJsonLd} />
  <JsonLd data={breadcrumbJsonLd} />

  <main id="main-content" tabindex="-1">
    <Section variant="compact">
      <Container size="content">
        <GuideHeader
          category={guide.category}
          title={guide.title}
          description={guide.description}
          publishAt={guide.publishAt}
          updatedAt={guide.updatedAt}
          breadcrumbs={breadcrumbs}
        />
      </Container>
    </Section>

    <Section aria-labelledby="article-content-title">
      <Container size="content">
        <article class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:text-ink-900 prose-p:leading-7 prose-li:leading-7 prose-a:font-medium prose-a:text-brand-700 prose-a:no-underline hover:prose-a:text-brand-800">
          <h2 id="article-content-title" class="sr-only">Article content</h2>

          <section aria-labelledby="why-title" class="not-prose">
            <h2 id="why-title" class="text-3xl font-semibold text-ink-900">Why this checklist exists</h2>
            <div class="mt-5 space-y-4 text-base leading-7 text-slate-700">
              <p>This is a flow-first launch risk review. It is for the parts of a change that can break completion, create avoidable compliance debt, or make rollback harder than it should be.</p>
              <p>Use it for websites, forms, booking or contact flows, ecommerce paths, accessibility-sensitive journeys, and conditional AI or automation touchpoints where relevant.</p>
              <p>If the path changed, the data path changed, or the handoff changed, review it here before go-live.</p>
            </div>
          </section>

          <section aria-labelledby="request-preview-title" class="not-prose mt-12">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700">Preview</p>
              <h2 id="request-preview-title" class="mt-2 text-3xl font-semibold text-ink-900">What this checklist covers</h2>
              <p class="mt-3 max-w-2xl text-base leading-7 text-slate-700">
                A short, dense review of the live path, the data it captures, the handoffs it triggers, and the proof you need before launch.
              </p>

              <div class="mt-6 grid gap-4 md:grid-cols-2">
                {requestPreviewPoints.map((point) => (
                  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-soft">
                    <h3 class="text-lg font-semibold text-ink-900">{point.title}</h3>
                    <p class="mt-2 text-sm leading-6 text-slate-700">{point.body}</p>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section aria-labelledby="guide-email-title" class="not-prose mt-12">
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700">Get it by email</p>
              <h2 id="guide-email-title" class="mt-2 text-3xl font-semibold text-ink-900">Get the full checklist by email</h2>
              <p class="mt-3 max-w-2xl text-base leading-7 text-slate-700">
                Leave your email and we&apos;ll send the full checklist link. The email keeps the same privacy and opt-in choices, but the delivered page is the full checklist view.
              </p>

              <div class="mt-6 space-y-4">
                <FormStatus
                  type="success"
                  title="Checklist sent"
                  message="Check your inbox for the link."
                  hidden
                  tabindex="-1"
                  data-guide-email-status="success"
                />
                <FormStatus
                  type="error"
                  title="Checklist not sent"
                  message="Something went wrong. Please check your email address and consent selection, then try again."
                  hidden
                  tabindex="-1"
                  data-guide-email-status="error"
                />
                <div data-guide-email-form-wrapper>
                  <GuideEmailForm guideSlug={guide.slug} returnTo={guide.href} />
                </div>
              </div>
            </div>
          </section>
        </article>
      </Container>
    </Section>

    <Section>
      <Container size="content">
        <GuideRelatedService
          title="Related service"
          label={guide.relatedService.label}
          href={guide.relatedService.href}
        />
      </Container>
    </Section>

    <Section>
      <Container size="content">
        <GuideRelatedGuides guides={relatedGuides} title="Related guides" />
      </Container>
    </Section>
  </main>

  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const state = params.get('resource');

      if (!state) {
        return;
      }

      const target = document.querySelector(`[data-guide-email-status="${state}"]`);

      if (!target) {
        return;
      }

      const wrapper = document.querySelector('[data-guide-email-form-wrapper]');

      target.hidden = false;

      if (state === 'success' && wrapper) {
        wrapper.hidden = true;
      }

      target.scrollIntoView({ block: 'start', behavior: 'auto' });

      if (typeof target.focus === 'function') {
        target.focus({ preventScroll: true });
      }
    })();
  </script>

  <Footer />
</BaseLayout>
