---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const schedulingLink = 'https://calendly.com/aldogustavomalasomma/15min';
const briefHref =
  'mailto:hello@copycodeai.online?subject=' + encodeURIComponent('EAA Structural Hardening Request');
---

<BaseLayout
  title="EAA Structural Hardening | CopyCodeAI"
  description="Technical accessibility review + structural fixes for EAA/WCAG readiness. Not legal consulting. Typical delivery 2–4 days."
  canonical="https://copycodeai.online/eaa-structural-hardening"
  ogTitle="EAA Structural Hardening | CopyCodeAI"
  ogDescription="Technical accessibility review + structural fixes for EAA/WCAG readiness. Not legal consulting. Typical delivery 2–4 days."
>
  <Navbar active="services" />

  <main id="main-content">
    <section class="mx-auto max-w-6xl px-6 py-14 sm:px-8 lg:px-12" aria-labelledby="eaa-hero-title">
      <h1 id="eaa-hero-title" class="text-4xl font-bold text-ink-900 sm:text-5xl">EAA Structural Hardening</h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-700">
        Technical accessibility review + structural fixes for EAA/WCAG readiness. Not legal advice.
      </p>
      <p class="mt-4 text-lg font-semibold text-slate-900">From €850</p>
      <p class="mt-1 text-sm text-slate-600">Typical delivery: 2-4 days</p>

      <div class="mt-7 flex flex-col gap-4 sm:flex-row">
        <a
          href={schedulingLink}
          class="inline-flex items-center justify-center rounded-xl bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-soft hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
        >
          Start with a 15-min Technical Assessment
        </a>
        <a
          href={briefHref}
          class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 hover:border-slate-400 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
        >
          Send a Brief
        </a>
      </div>
    </section>

    <section class="bg-white py-14" aria-label="Scope">
      <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-12 space-y-12">
        <section aria-labelledby="what-you-get-title">
          <h2 id="what-you-get-title" class="mb-4 text-3xl font-semibold text-ink-900">What you get</h2>
          <ul class="max-w-3xl list-disc space-y-2 pl-5 text-slate-700">
            <li>Critical user-journey accessibility review (keyboard + focus + forms)</li>
            <li>Semantic structure fixes (headings, landmarks, labels)</li>
            <li>Navigation and interaction hardening (menus, dialogs, states)</li>
            <li>Contrast and text legibility checks (practical readiness pass)</li>
            <li>Fix list with priorities (quick wins vs deeper changes)</li>
            <li>Implementation of agreed structural fixes (within scope)</li>
            <li>Developer handoff notes (what changed + why)</li>
            <li>Retest pass on the fixed flows</li>
          </ul>
        </section>

        <section aria-labelledby="not-included-title">
          <h2 id="not-included-title" class="mb-4 text-3xl font-semibold text-ink-900">What this is not</h2>
          <ul class="max-w-3xl list-disc space-y-2 pl-5 text-slate-700">
            <li>Not legal consulting</li>
            <li>Not a WCAG/EAA certification</li>
            <li>Not a full redesign</li>
            <li>Not ongoing accessibility monitoring</li>
          </ul>
        </section>
      </div>
    </section>

    <section class="bg-slate-50 py-14" aria-label="How and FAQ">
      <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-12">
        <section class="pb-6 md:pb-8" aria-labelledby="process-title">
          <h2 id="process-title" class="mb-6 text-3xl font-semibold text-ink-900">Process</h2>
          <ol class="grid gap-5 md:grid-cols-3">
            <li class="rounded-xl border border-slate-200 bg-white p-6 shadow-soft">
              <p class="text-sm font-semibold uppercase tracking-wide text-slate-700">1. Quick Technical Review (15 min)</p>
            </li>
            <li class="rounded-xl border border-slate-200 bg-white p-6 shadow-soft">
              <p class="text-sm font-semibold uppercase tracking-wide text-slate-700">2. Fix Scope & Delivery Window (2-4 days)</p>
            </li>
            <li class="rounded-xl border border-slate-200 bg-white p-6 shadow-soft">
              <p class="text-sm font-semibold uppercase tracking-wide text-slate-700">3. Implementation, Retest & Handoff</p>
            </li>
          </ol>
        </section>

        <div class="mt-14 border-t border-slate-200/60 pt-10 md:mt-16"></div>

        <section aria-labelledby="faq-title" class="scroll-mt-24">
          <h2 id="faq-title" class="mb-2 text-3xl font-semibold text-ink-900">FAQ</h2>
          <p class="mb-6 text-sm text-slate-600">Quick answers on scope, compliance boundaries, and delivery.</p>

          <div class="space-y-3">
            <details class="border-b border-slate-200/70 py-3">
              <summary class="cursor-pointer py-1 font-medium leading-relaxed text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2">Is this legal EAA compliance?</summary>
              <p class="pt-3 text-sm text-slate-600">No. This is technical readiness and structural fixes aligned with EAA/WCAG expectations. It is not legal advice.</p>
            </details>

            <details class="border-b border-slate-200/70 py-3">
              <summary class="cursor-pointer py-1 font-medium leading-relaxed text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2">Do you test with screen readers?</summary>
              <p class="pt-3 text-sm text-slate-600">Yes, basic practical checks can be included. Scope depends on the project; focus is structural readiness.</p>
            </details>

            <details class="border-b border-slate-200/70 py-3">
              <summary class="cursor-pointer py-1 font-medium leading-relaxed text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2">What does “structural fixes” mean?</summary>
              <p class="pt-3 text-sm text-slate-600">Semantics, labels, focus order, navigation patterns, and related interaction structure fixes.</p>
            </details>

            <details class="border-b border-slate-200/70 py-3">
              <summary class="cursor-pointer py-1 font-medium leading-relaxed text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2">Can you work on my existing stack?</summary>
              <p class="pt-3 text-sm text-slate-600">Yes. Scope depends on your current stack and implementation constraints.</p>
            </details>

            <details class="border-b border-slate-200/70 py-3">
              <summary class="cursor-pointer py-1 font-medium leading-relaxed text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2">Will you change the design?</summary>
              <p class="pt-3 text-sm text-slate-600">Only minimal visual changes when needed to fix accessibility-critical issues.</p>
            </details>

            <details class="border-b border-slate-200/70 py-3">
              <summary class="cursor-pointer py-1 font-medium leading-relaxed text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2">What do you need from us?</summary>
              <p class="pt-3 text-sm text-slate-600">A live URL, critical flows, target audience context, and any known issues.</p>
            </details>

            <details class="border-b border-slate-200/70 py-3">
              <summary class="cursor-pointer py-1 font-medium leading-relaxed text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2">Do you provide an accessibility statement?</summary>
              <p class="pt-3 text-sm text-slate-600">I provide a technical summary and implementation notes only.</p>
            </details>

            <details class="border-b border-slate-200/70 py-3">
              <summary class="cursor-pointer py-1 font-medium leading-relaxed text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2">How do you define scope?</summary>
              <p class="pt-3 text-sm text-slate-600">Fixed window with an agreed list of fixes and deliverables.</p>
            </details>
          </div>
        </section>

        <section class="mt-12 md:mt-16" aria-labelledby="final-cta-title">
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm md:p-10">
            <h2 id="final-cta-title" class="text-2xl font-semibold text-ink-900">Want to harden accessibility before you scale?</h2>
            <div class="mt-5 flex flex-col gap-4 sm:flex-row">
              <a
                href={schedulingLink}
                class="inline-flex items-center justify-center rounded-xl bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-soft hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
              >
                Start with a 15-min Technical Assessment
              </a>
              <a
                href={briefHref}
                class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 hover:border-slate-400 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
              >
                Send a Brief
              </a>
            </div>
            <p class="mt-3 text-sm text-slate-600">Written summary after the call.</p>
          </div>
        </section>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
