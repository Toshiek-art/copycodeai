---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/layout/Section.astro';
import Container from '../../components/layout/Container.astro';
import CTAGroup from '../../components/layout/CTAGroup.astro';
import { getWorkProject } from '../../data/work';

const project = getWorkProject('pasta-lab');
---

<BaseLayout
  title="Pasta Lab Concept Demo | CopyCodeAI"
  description="A fictional restaurant concept demo used to show multilingual entry, booking flow, and hospitality branding."
  canonical="https://copycodeai.online/work/pasta-lab"
  ogTitle="Pasta Lab Concept Demo | CopyCodeAI"
  ogDescription="A fictional restaurant concept demo used to show multilingual entry, booking flow, and hospitality branding."
>
  <Navbar active="work" />

  <main id="main-content" tabindex="-1">
    <Section variant="compact" aria-labelledby="pasta-lab-title">
      <Container size="content">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">Concept Demo</p>
        <h1 id="pasta-lab-title" class="mt-3 text-4xl font-bold leading-tight text-ink-900 sm:text-5xl">{project?.title ?? 'Pasta Lab'}</h1>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-slate-700">
          A fictional restaurant site used to demonstrate multilingual entry, reservation flow, and brand clarity without relying on heavy visuals.
        </p>
        <p class="mt-3 text-sm text-slate-600">
          This is a concept demo, not a client case. The goal is to show execution quality and transparent labeling.
        </p>

        <CTAGroup>
          <a
            href="https://pastalab-tallinn.vercel.app/"
            class="inline-flex items-center justify-center rounded-xl bg-brand-700 px-6 py-3 text-sm font-semibold text-white shadow-soft hover:bg-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open demo site
          </a>
          <a
            href="/work"
            class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 hover:border-slate-400 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
          >
            Back to Selected Work
          </a>
        </CTAGroup>
      </Container>
    </Section>

    <Section variant="plain">
      <Container size="wide">
        {(project?.screenshots?.desktop || project?.screenshots?.mobile) && (
          <div class="grid gap-4 lg:grid-cols-2">
            {project?.screenshots?.desktop && (
              <figure class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-soft">
                <picture class="block">
                  {project?.screenshots?.mobile && (
                    <source media="(max-width: 639px)" srcset={project.screenshots.mobile.src} />
                  )}
                  <source media="(min-width: 640px)" srcset={project.screenshots.desktop.src} />
                  <img
                    src={project.screenshots.desktop.src}
                    alt={project.screenshots.desktop.alt}
                    width={project.screenshots.desktop.width}
                    height={project.screenshots.desktop.height}
                    class="aspect-[16/10] w-full object-cover object-top"
                    loading="lazy"
                    decoding="async"
                    sizes="(min-width: 1024px) 50vw, 100vw"
                  />
                </picture>
                <figcaption class="px-4 py-3 text-xs font-medium text-slate-600">Desktop screenshot</figcaption>
              </figure>
            )}
            {project?.screenshots?.mobile && (
              <figure class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-soft">
                <img
                  src={project.screenshots.mobile.src}
                  alt={project.screenshots.mobile.alt}
                  width={project.screenshots.mobile.width}
                  height={project.screenshots.mobile.height}
                  class="aspect-[9/16] w-full object-cover"
                  loading="lazy"
                  decoding="async"
                  sizes="(min-width: 1024px) 50vw, 100vw"
                />
                <figcaption class="px-4 py-3 text-xs font-medium text-slate-600">Mobile screenshot</figcaption>
              </figure>
            )}
          </div>
        )}

        <div class="mt-6 grid gap-6 lg:grid-cols-3">
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-600">What it demonstrates</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-700">
              A hospitality layout can still feel premium when the language switch, booking entry, and menu hierarchy are kept simple.
            </p>
          </article>
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-600">What is kept tight</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-700">
              No fake case-study language, no agency gloss, and no unnecessary motion. The page stays direct and readable.
            </p>
          </article>
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-600">What it is for</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-700">
              A compact concept build for later refinement with real brand assets, menu content, and photography.
            </p>
          </article>
        </div>
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
