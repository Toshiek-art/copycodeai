---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/layout/Section.astro';
import Container from '../../components/layout/Container.astro';
import CTAGroup from '../../components/layout/CTAGroup.astro';
import TechnicalAudit from '../../components/work/TechnicalAudit.astro';
import type { WorkProject } from '../../data/work';
import { workProjects } from '../../data/work';

interface Props {
  project: WorkProject;
}

const toneClasses = {
  emerald: 'from-emerald-950 via-slate-900 to-slate-800',
  slate: 'from-slate-950 via-slate-800 to-slate-700',
  amber: 'from-amber-950 via-stone-900 to-slate-800'
} as const;

const statusNotes: Record<WorkProject['status'], string> = {
  Live: 'The live build stays separate from this detail page so the proof remains easy to inspect.',
  'Concept Demo': 'The demo label is explicit here, so the scope stays honest and easy to understand.',
  'Portfolio Build': 'The portfolio build is labeled clearly so it reads as proof-of-work, not client work.'
};

export const getStaticPaths = (() =>
  workProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }))) satisfies GetStaticPaths;

const { project } = Astro.props as Props;
const screenshots = project.screenshots ?? {};
---

<BaseLayout
  title={`${project.title} | CopyCodeAI`}
  description={project.summary}
  canonical={`https://copycodeai.online/work/${project.slug}`}
  ogTitle={`${project.title} | CopyCodeAI`}
  ogDescription={project.summary}
>
  <Navbar active="work" />

  <main id="main-content" tabindex="-1">
    <Section variant="compact" aria-labelledby="work-detail-title">
      <Container size="content">
        <div class={`mb-6 h-2 w-full rounded-full bg-gradient-to-r ${toneClasses[project.previewTone]}`} aria-hidden="true"></div>
        <div class="max-w-3xl">
          <div class="flex flex-wrap gap-2">
            <span class="inline-flex rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-600">
              {project.typeLabel}
            </span>
            <span class="inline-flex rounded-full border border-slate-200 bg-slate-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-700">
              {project.status}
            </span>
          </div>

          <p class="mt-4 text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">Work detail</p>
          <h1 id="work-detail-title" class="mt-3 text-4xl font-bold leading-tight text-ink-900 sm:text-5xl">{project.title}</h1>
          <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">{project.summary}</p>
          <p class="mt-3 max-w-3xl text-sm leading-relaxed text-slate-600">{statusNotes[project.status]}</p>

          <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-slate-700">
            <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1">{project.previewLabel}</span>
            <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1">{project.linkLabel}</span>
            <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1">Selected work detail</span>
          </div>

          <CTAGroup>
            <a
              href={project.href}
              class="inline-flex items-center justify-center rounded-xl bg-brand-700 px-6 py-3 text-sm font-semibold text-white shadow-soft hover:bg-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
              target="_blank"
              rel="noopener noreferrer"
            >
              {project.linkLabel}
            </a>
            <a
              href="/work"
              class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 hover:border-slate-400 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
            >
              Back to Selected Work
            </a>
          </CTAGroup>
        </div>
      </Container>
    </Section>

    <Section variant="plain">
      <Container size="wide">
        {(screenshots.desktop || screenshots.mobile) && (
          <div class="grid gap-4 lg:grid-cols-2">
            {screenshots.desktop && (
              <figure class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-soft">
                <picture class="block">
                  {screenshots.mobile && (
                    <source media="(max-width: 639px)" srcset={screenshots.mobile.src} />
                  )}
                  <source media="(min-width: 640px)" srcset={screenshots.desktop.src} />
                  <img
                    src={screenshots.desktop.src}
                    alt={screenshots.desktop.alt}
                    width={screenshots.desktop.width}
                    height={screenshots.desktop.height}
                    class="aspect-[16/10] w-full object-cover object-top"
                    loading="lazy"
                    decoding="async"
                    sizes="(min-width: 1024px) 50vw, 100vw"
                  />
                </picture>
                <figcaption class="px-4 py-3 text-xs font-medium text-slate-600">Desktop screenshot</figcaption>
              </figure>
            )}
            {screenshots.mobile && (
              <figure class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-soft">
                <img
                  src={screenshots.mobile.src}
                  alt={screenshots.mobile.alt}
                  width={screenshots.mobile.width}
                  height={screenshots.mobile.height}
                  class="aspect-[9/16] w-full object-cover"
                  loading="lazy"
                  decoding="async"
                  sizes="(min-width: 1024px) 50vw, 100vw"
                />
                <figcaption class="px-4 py-3 text-xs font-medium text-slate-600">Mobile screenshot</figcaption>
              </figure>
            )}
          </div>
        )}

        <div class="mt-6 grid gap-6 lg:grid-cols-3">
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-600">What it demonstrates</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-700">
              {project.bullets[0]}
            </p>
          </article>
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-600">What is kept tight</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-700">
              {project.bullets[1]}
            </p>
          </article>
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-600">What it is for</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-700">
              {project.bullets[2]}
            </p>
          </article>
        </div>

        {project.lighthouse && (
          <div class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]">
            <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-600">How to read this page</p>
              <p class="mt-3 text-sm leading-relaxed text-slate-700">
                The detail page gives the project a stable internal URL, while the primary button still opens the live build or demo in a new tab.
              </p>
              <p class="mt-3 text-sm leading-relaxed text-slate-700">
                That keeps the portfolio transparent: the internal page is for context and proof, and the external site is for the actual experience.
              </p>
            </article>

            <TechnicalAudit project={project} />
          </div>
        )}
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
