---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import ServiceCards from '../components/ServiceCards.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
---

<BaseLayout
  title="Services | CopyCodeAI"
  description="Explore CopyCodeAI launch-first services: compliance-ready landing pages, AI feature integration, and EAA structural hardening."
  canonical="https://copycodeai.online/services"
  includeOfferSync={true}
>
  <Navbar active="services" />

  <main id="main-content" tabindex="-1">
    <Section aria-labelledby="services-page-title">
      <Container size="content">
        <h1 id="services-page-title" class="text-4xl font-bold text-ink-900 sm:text-5xl">Services</h1>
        <p class="mt-4 max-w-3xl text-lg text-slate-700">
          Launch-first engineering tracks for early-stage European startups that need fixed scope, clear delivery windows, and compliance-aware implementation.
        </p>
        <p class="mt-2 text-sm text-slate-600">Scope note: technical implementation guidance only. No legal advice is provided.</p>
        <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-slate-600">
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1">Fixed-scope delivery</span>
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1">Written handoff</span>
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1">Not a full redesign</span>
        </div>
      </Container>
    </Section>

    <ServiceCards
      heading="Fast Launch Offers"
      intro="Choose the intervention that fits your current stage: launch, automation, or accessibility hardening."
    />

    <Section class="pb-16 sm:pb-20 lg:pb-24" aria-labelledby="detailed-offers-title">
      <Container size="wide">
        <h2 id="detailed-offers-title" class="text-3xl font-semibold text-ink-900">Detailed Scope and Boundaries</h2>

        <div class="mt-8 grid gap-6 xl:gap-8">
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft lg:p-8">
            <h3 class="text-2xl font-semibold text-slate-900">A) Compliance-Ready Landing Page</h3>
            <p class="mt-2 text-slate-700">Launch-ready landing or MVP implementation with GDPR-aware structure and EAA/WCAG-aware UX foundations.</p>
            <h4 class="mt-4 text-sm font-semibold uppercase tracking-wide text-slate-700">What you get</h4>
            <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-700">
              <li>Form and data-routing structure with traceable touchpoints.</li>
              <li>Accessibility readiness pass for core user flows.</li>
              <li>Deployment and handoff notes for immediate use.</li>
            </ul>
            <h4 class="mt-4 text-sm font-semibold uppercase tracking-wide text-slate-700">Boundaries</h4>
            <p class="mt-2 text-sm text-slate-600">Technical implementation and structural readiness only; not legal advice or certification.</p>
          </article>

          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft lg:p-8">
            <h3 class="text-2xl font-semibold text-slate-900">B) AI Feature Integration</h3>
            <p class="mt-2 text-slate-700">Structured automation workflows for onboarding, support, and internal operations when manual handling becomes a bottleneck.</p>
            <h4 class="mt-4 text-sm font-semibold uppercase tracking-wide text-slate-700">What you get</h4>
            <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-700">
              <li>Workflow definition from input to output, with clear boundaries.</li>
              <li>Implementation notes for integration, guardrails, and validation.</li>
              <li>Operational handoff notes for startup teams.</li>
            </ul>
            <h4 class="mt-4 text-sm font-semibold uppercase tracking-wide text-slate-700">Boundaries</h4>
            <p class="mt-2 text-sm text-slate-600">Fixed-scope feature integration only; not model training or full-platform rebuilds.</p>
          </article>

          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft lg:p-8">
            <h3 class="text-2xl font-semibold text-slate-900">C) EAA Structural Hardening</h3>
            <p class="mt-2 text-slate-700">Structural accessibility corrections aligned with EAA / WCAG for critical user journeys before growth phases.</p>
            <h4 class="mt-4 text-sm font-semibold uppercase tracking-wide text-slate-700">What you get</h4>
            <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-700">
              <li>Prioritized fix list for structural accessibility issues.</li>
              <li>Code-level adjustments for semantics, focus, and interaction patterns.</li>
              <li>Retest notes and handoff documentation.</li>
            </ul>
            <h4 class="mt-4 text-sm font-semibold uppercase tracking-wide text-slate-700">Boundaries</h4>
            <p class="mt-2 text-sm text-slate-600">Technical accessibility hardening only; not legal consulting and not certification.</p>
          </article>
        </div>
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
