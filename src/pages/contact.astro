---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
import CTAGroup from '../components/layout/CTAGroup.astro';
import ConsultationForm from '../components/forms/ConsultationForm.astro';
import FormStatus from '../components/forms/FormStatus.astro';

const calendlyUrl = 'https://calendly.com/aldogustavomalasomma/15min';

---

<BaseLayout
  title="Contact | CopyCodeAI"
  description="Contact CopyCodeAI through the consultation form for GDPR and EAA-aligned AI implementation support."
  canonical="https://copycodeai.online/contact"
>
  <Navbar active="contact" />

  <main id="main-content" tabindex="-1">
    <Section aria-labelledby="contact-page-title">
      <Container size="content">
        <h1 id="contact-page-title" class="text-4xl font-bold text-ink-900 sm:text-5xl">Let’s assess your system.</h1>
        <p class="mt-4 max-w-3xl text-lg text-slate-700">
          Choose the path that fits best: send a structured request through the form, or book a call directly in Calendly.
        </p>
        <p class="mt-2 text-slate-700">The request path keeps everything in one place. The booking path goes straight to Calendly.</p>
        <p class="mt-2 text-sm text-slate-600">Both paths stay separate so you can pick the one that matches how much context you want to share first.</p>
      </Container>
    </Section>

    <Section class="pb-8 sm:pb-10" aria-labelledby="contact-intake-title">
      <Container size="wide">
        <div class="mb-8 space-y-4">
          <div
            id="contact-status-success"
            hidden
            tabindex="-1"
            class="rounded-3xl border-4 border-emerald-300 bg-emerald-50 p-6 text-emerald-950 shadow-2xl"
            role="status"
            aria-live="polite"
          >
            <p class="text-sm font-black uppercase tracking-[0.28em] text-emerald-700">Thanks, we got it</p>
            <p class="mt-3 text-2xl font-semibold leading-tight sm:text-3xl">
              Your consultation request has been received. We’ll review it and reply as soon as possible, usually by email first.
            </p>
          </div>

          <div
            id="contact-status-error"
            hidden
            tabindex="-1"
            class="rounded-2xl border border-red-200 bg-red-50 p-4 text-red-950 shadow-soft sm:p-5"
            role="alert"
            aria-live="assertive"
          >
            <p class="text-sm font-semibold uppercase tracking-[0.18em]">Request not sent</p>
            <p class="mt-2 text-sm leading-6">
              Something in the form was missing or invalid. Please check the fields below and send it again.
            </p>
          </div>

        </div>

        <div class="grid gap-6 lg:grid-cols-[minmax(0,1.5fr)_minmax(320px,1fr)]">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8 lg:p-10">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-700">Structured request</p>
            <h2 id="contact-intake-title" class="mt-2 text-3xl font-semibold text-ink-900">Tell us what you’re building</h2>
            <p class="mt-3 max-w-2xl text-base leading-7 text-slate-700">
              Share the basics and we’ll review the context before replying. This is the best path if you want a structured async request.
            </p>

            <div class="mt-6" data-contact-form-wrapper>
              <FormStatus
                type="error"
                title="Request not sent"
                message="Something in the form was missing or invalid. Please check the fields below and send it again."
                class="shadow-soft ring-1 ring-inset ring-black/5"
                hidden
                data-contact-status="error"
              />
              <FormStatus
                type="success"
                title="Thanks, we got it"
                message="Your consultation request has been received. We’ll review it and reply as soon as possible, usually by email first."
                class="shadow-soft ring-1 ring-inset ring-black/5"
                hidden
                data-contact-status="success"
              />
              <div class="mt-6">
                <ConsultationForm />
              </div>
            </div>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-soft sm:p-8 lg:p-10">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-700">Book a call</p>
            <h2 class="mt-2 text-3xl font-semibold text-ink-900">Go straight to Calendly</h2>
            <p class="mt-3 text-base leading-7 text-slate-700">
              If you already know you want a live conversation, book directly in Calendly. It will collect the details needed for the call there.
            </p>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              That keeps the booking flow separate from the structured request form.
            </p>
            <CTAGroup class="mt-6 flex-col">
              <a
                href={calendlyUrl}
                class="inline-flex items-center justify-center rounded-xl bg-brand-700 px-5 py-3 text-sm font-semibold text-white hover:bg-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
              >
                Book a call in Calendly
              </a>
            </CTAGroup>
          </div>
        </div>
      </Container>
    </Section>
  </main>

  <Footer />
  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const contact = params.get('contact');
      let target = null;
      if (contact === 'success') {
        target = 'success';
      } else if (contact === 'error') {
        target = 'error';
      }

      if (!target) {
        return;
      }

      const banner = document.querySelector(`[data-contact-status="${target}"]`);
      if (!banner) {
        return;
      }

      banner.hidden = false;
      if (target === 'success') {
        const formWrapper = document.querySelector('[data-contact-form-wrapper]');
        if (formWrapper) {
          formWrapper.hidden = true;
        }
      }
      banner.scrollIntoView({ block: 'start', behavior: 'auto' });
      if (typeof banner.focus === 'function') {
        banner.focus({ preventScroll: true });
      }
    })();
  </script>
</BaseLayout>
