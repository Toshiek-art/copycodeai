---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';

const redirectHref = '/#blueprint';
---

<BaseLayout
  title="Blueprint | CopyCodeAI"
  description="Redirecting to the Blueprint section on the home page."
  robots="noindex, follow"
  ogTitle="Blueprint | CopyCodeAI"
  ogDescription="Redirecting to the Blueprint section on the home page."
  metaRefresh={`0;url=${redirectHref}`}
>
  <Navbar />

  <main id="main-content" tabindex="-1">
    <Section aria-labelledby="blueprint-redirect-title">
      <Container size="narrow">
        <h1 id="blueprint-redirect-title" class="text-3xl font-bold text-ink-900">Redirecting to Blueprint</h1>
        <p class="mt-4 text-slate-700">
          If you are not redirected automatically, continue to
          <a href={redirectHref} class="underline decoration-slate-300 underline-offset-4 hover:text-brand-700">the Blueprint section</a>.
        </p>
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
