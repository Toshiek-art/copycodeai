---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
import SelectedWork from '../components/SelectedWork.astro';
---

<BaseLayout
  title="Selected Work | CopyCodeAI"
  description="Selected work from CopyCodeAI: Toyb, Coherence Mind, Pasta Lab, and AuditLab."
  canonical="https://copycodeai.online/work"
  ogTitle="Selected Work | CopyCodeAI"
  ogDescription="Selected work from CopyCodeAI: Toyb, Coherence Mind, Pasta Lab, and AuditLab."
>
  <Navbar active="work" />

  <main id="main-content" tabindex="-1">
    <Section variant="compact" aria-labelledby="work-title">
      <Container size="content">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">Selected Work</p>
        <h1 id="work-title" class="mt-2 text-4xl font-bold text-ink-900 sm:text-5xl">Toyb, Coherence Mind, Pasta Lab, and AuditLab.</h1>
        <p class="mt-3 max-w-3xl text-lg text-slate-700">
          Proof of execution, not a decorative gallery. Two live sites, one concept demo, and one public portfolio build are labeled clearly so the scope stays transparent.
        </p>
        <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-slate-700">
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1">2 live sites</span>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1">1 concept demo</span>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1">1 portfolio build</span>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1">Direct links</span>
        </div>
        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-600">
          Project titles and detail links open the internal case pages. The labeled buttons open the live builds or demo sites.
        </p>
      </Container>
    </Section>

    <SelectedWork
      heading="Selected Work"
      intro="Toyb, Coherence Mind, Pasta Lab, and AuditLab. The focus is on launch structure, content hierarchy, transparent labeling, and mobile-first execution."
      showAudit={true}
      showAuditSignal={false}
      showCta={false}
    />

    <Section variant="muted">
      <Container size="content">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
          <h2 class="text-2xl font-semibold text-ink-900">Reading the labels</h2>
          <ul class="mt-4 space-y-3 text-sm leading-relaxed text-slate-700">
            <li>Live means the site is online and usable now.</li>
            <li>Concept Demo means the site is fictional but intentionally designed to show execution quality.</li>
            <li>Portfolio Build means a public build used to show execution quality without implying client ownership.</li>
            <li>The work stays compact on mobile and expands cleanly on larger screens.</li>
            <li>Project titles open the dedicated detail pages; the buttons open the external builds.</li>
          </ul>
        </div>
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
