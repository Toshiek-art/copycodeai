---
import Section from './layout/Section.astro';
import Container from './layout/Container.astro';

interface Props {
  heading?: string;
  intro?: string;
}

const {
  heading = 'Fast Launch Offers',
  intro = 'Launch-first interventions for early-stage teams that need clear scope and fast delivery.'
} = Astro.props;

const services = [
  {
    title: 'Compliance-Ready Landing Page',
    linkLabel: 'Explore landing page offer',
    description: 'A startup landing page or MVP site built to help you launch fast without creating avoidable GDPR or accessibility issues.',
    href: '/compliance-ready-landing',
    price: 'From €750',
    delivery: 'Typical delivery: 3-5 days',
    promo: 'Local Launch Offer (Tallinn-based teams): €650 (limited slots) · Ends 31 May 2026 (EEST)',
    promoNote: 'Available to Tallinn-based teams.',
    points: [
      'Launch landing or MVP pages with GDPR-aware form and data-flow structure.',
      'Build accessibility-ready UX foundations (keyboard, focus, semantics).',
      'Fixed scope with technical handoff notes.'
    ],
    icon: 'workflow'
  },
  {
    title: 'AI Feature Integration',
    linkLabel: 'Explore AI integration offer',
    description: 'Add useful automation when manual workflows start slowing your team down — without overengineering the product.',
    href: '/ai-feature-integration',
    price: 'From €900',
    delivery: 'Typical delivery: 5-7 days',
    points: [
      'Workflow mapping and implementation guardrails aligned with real operations.',
      'Add guardrails and data boundaries for safer operational workflows.',
      'Tactical implementation with handoff notes.'
    ],
    icon: 'shield'
  },
  {
    title: 'EAA Structural Hardening',
    linkLabel: 'Explore accessibility hardening offer',
    description: 'Fix structural accessibility issues at code level so your product is easier to use, safer to scale, and closer to EAA/WCAG expectations.',
    href: '/eaa-structural-hardening',
    price: 'From €850',
    delivery: 'Typical delivery: 2-4 days',
    points: [
      'Prioritized remediation for critical user flows.',
      'Code-level fixes for semantics, focus, and interaction patterns.',
      'Retest pass on corrected journeys.'
    ],
    icon: 'universal'
  }
];
---

<Section id="services" aria-labelledby="services-title">
  <Container size="wide">
    <h2 id="services-title" class="text-3xl font-semibold text-ink-900">{heading}</h2>
    <p class="mt-2 max-w-2xl text-slate-600">{intro}</p>

    <div class="mt-8 grid gap-6 lg:grid-cols-3" role="list" aria-label="CopyCodeAI services">
      {services.map((service, index) => (
        <article
          class="reveal-up rounded-2xl border border-slate-200 bg-white p-6 shadow-soft xl:p-7"
          data-reveal="service-card"
          style={`transition-delay: ${index * 120}ms;`}
          role="listitem"
        >
        <div class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700" aria-hidden="true">
          {
            service.icon === 'workflow' && (
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7">
                <path d="M7 4h10v4H7zM4 16h6v4H4zM14 16h6v4h-6z"></path>
                <path d="M12 8v4m0 0H7m5 0h5"></path>
              </svg>
            )
          }
          {
            service.icon === 'shield' && (
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7">
                <path d="M12 3l7 3v6c0 5-3 7.5-7 9-4-1.5-7-4-7-9V6l7-3z"></path>
                <path d="m9 12 2 2 4-4"></path>
              </svg>
            )
          }
          {
            service.icon === 'universal' && (
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7">
                <circle cx="12" cy="5" r="2"></circle>
                <path d="M4 9h16M12 7v12m-4 0 4-6 4 6"></path>
              </svg>
            )
          }
        </div>

          <h3 class="text-xl font-semibold leading-snug text-slate-900">{service.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-700">{service.description}</p>
          <a
            href={service.href}
            class="mt-2 inline-flex text-sm font-medium text-slate-800 underline decoration-slate-300 underline-offset-4 hover:text-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
            aria-label={service.linkLabel}
          >
            {service.linkLabel}
          </a>
          <p class="mt-3 text-sm font-semibold text-slate-900">{service.price}</p>
          <p class="mt-1 text-sm text-slate-600">{service.delivery}</p>
          {service.promo && (
            <div class="mt-3 rounded-lg border border-emerald-200 bg-emerald-50/70 p-3" data-offer-key="tallinn_landing_2026">
              <p class="text-sm font-semibold text-emerald-900" data-offer="price">{service.promo}</p>
              <p class="mt-1 text-xs text-emerald-800" data-offer="deadline">Tallinn-based teams · Ends 31 May 2026 (EEST)</p>
              <p class="mt-1 text-xs font-medium text-emerald-900" data-offer="slots" aria-live="polite">Slots left: 5</p>
              {service.promoNote && <p class="mt-1 text-xs text-slate-600" data-offer="active">{service.promoNote}</p>}
            </div>
          )}
          <ul class="mt-4 space-y-2 text-sm leading-relaxed text-slate-700">
            {service.points.map((point) => (
              <li class="flex gap-2">
                <span class="mt-1 h-2 w-2 rounded-full bg-brand-500" aria-hidden="true"></span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </Container>
</Section>

<script is:inline>
  (() => {
    const cards = document.querySelectorAll('[data-reveal="service-card"]');
    if (!cards.length) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion || !('IntersectionObserver' in window)) {
      cards.forEach((card) => card.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            obs.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.2,
        rootMargin: '0px 0px -24px 0px'
      }
    );

    cards.forEach((card) => observer.observe(card));
  })();
</script>
