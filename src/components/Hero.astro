---
import Container from './layout/Container.astro';
import CTAGroup from './layout/CTAGroup.astro';

const schedulingLink = 'https://calendly.com/aldogustavomalasomma/15min';
const briefHref = '/contact#structured-request';
---

<section class="relative overflow-hidden bg-gradient-to-br from-emerald-100 via-cyan-50 to-slate-100 py-20 sm:py-24 lg:py-28">
  <div class="absolute -left-20 top-0 h-72 w-72 rounded-full bg-emerald-200/70 blur-3xl" aria-hidden="true"></div>
  <div class="absolute right-0 top-20 h-72 w-72 rounded-full bg-cyan-200/70 blur-3xl" aria-hidden="true"></div>

  <Container size="wide" class="relative">
    <p class="inline-flex rounded-full border border-emerald-300/80 bg-white/80 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-emerald-800">
      For European startups and digital businesses that need to launch fast — without compliance mistakes
    </p>
    <h1 class="mt-5 max-w-4xl text-4xl font-bold leading-tight text-slate-900 sm:text-5xl lg:text-6xl">
      Launch websites, products, and AI features without creating GDPR or EAA problems you’ll pay later.
    </h1>
    <p class="mt-3 max-w-4xl text-2xl font-semibold leading-tight text-slate-800 sm:text-3xl">
      I help European startups and digital businesses build MVPs, landing pages, booking flows, forms, and AI features with the right technical and compliance foundations in place.
    </p>
    <p class="mt-5 max-w-3xl text-lg leading-relaxed text-slate-700">
      Move fast now, without creating GDPR issues, accessibility gaps, or technical debt that slows you down later.
    </p>
    <p class="mt-3 max-w-3xl text-base leading-relaxed text-slate-600">
      Relevant work includes websites, forms, booking flows, analytics, ecommerce journeys, contact paths, and AI-enabled features where compliance and launch clarity matter.
    </p>

    <CTAGroup>
      <a
        href={schedulingLink}
        class="inline-flex items-center justify-center rounded-xl bg-brand-700 px-6 py-3 text-sm font-semibold text-white shadow-soft hover:bg-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
      >
        Start with a 15-min Technical Assessment
      </a>
      <a
        href={briefHref}
        class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 hover:border-slate-400 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
      >
        Send a Brief
      </a>
    </CTAGroup>
    <p class="mt-2 text-xs font-normal text-slate-600">
      No pressure. You’ll get a written follow-up.
    </p>
    <p class="mt-1 text-xs font-normal text-slate-600">
      You’ll book a short technical assessment in Calendly.
    </p>

    <p class="mt-4 text-sm text-slate-600">
      Engineering-first help for founders. Not a marketing agency. Not generic consulting.
    </p>
    <p class="mt-1 text-sm text-slate-600">
      Based in Tallinn, working with startups and digital businesses across Europe
    </p>
  </Container>
</section>
