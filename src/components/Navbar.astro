---
interface Props {
  active?: 'home' | 'services' | 'contact';
}

const { active } = Astro.props;

const blueprintHref = active === 'home' ? '#blueprint' : '/#blueprint';

const links = [
  { key: 'home', href: '/', label: 'Home' },
  { key: 'blueprint', href: blueprintHref, label: 'Blueprint' },
  { key: 'services', href: '/services', label: 'Services' },
  { key: 'contact', href: '/contact', label: 'Contact' }
] as const;
---

<header class="border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 sm:px-8 lg:px-12">
    <a href="/" class="text-lg font-semibold tracking-tight text-ink-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2" aria-label="Go to CopyCodeAI home page">CopyCodeAI</a>
    <nav aria-label="Main navigation" class="flex items-center gap-5">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-slate-700 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
            aria-current={active === link.key ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
