---
import type { WorkProject } from '../../data/work';
import TechnicalAudit from './TechnicalAudit.astro';

interface Props {
  project: WorkProject;
  showAudit?: boolean;
}

const { project, showAudit = false } = Astro.props;

const statusClasses: Record<WorkProject['status'], string> = {
  Live: 'border-emerald-200 bg-emerald-50 text-emerald-800',
  'Concept Demo': 'border-slate-200 bg-slate-100 text-slate-700',
  'Portfolio Build': 'border-brand-100 bg-brand-50 text-brand-800'
};

const toneClasses = {
  emerald: 'from-emerald-950 via-slate-900 to-slate-800',
  slate: 'from-slate-950 via-slate-800 to-slate-700',
  amber: 'from-amber-950 via-stone-900 to-slate-800'
} as const;

const barClasses = {
  emerald: ['bg-emerald-300/30', 'bg-emerald-200/25', 'bg-emerald-100/20'],
  slate: ['bg-white/25', 'bg-white/20', 'bg-white/10'],
  amber: ['bg-amber-200/30', 'bg-amber-100/20', 'bg-white/10']
} as const;

const desktopScreenshot = project.screenshots?.desktop;
const mobileScreenshot = project.screenshots?.mobile;
---

<article class="reveal-up flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-soft" data-reveal="selected-work-card">
  <div class="aspect-[16/10] overflow-hidden border-b border-slate-200 bg-slate-100">
    {desktopScreenshot ? (
      <picture class="block h-full w-full">
        {mobileScreenshot && (
          <source
            media="(max-width: 639px)"
            srcset={mobileScreenshot.src}
          />
        )}
        <source
          media="(min-width: 640px)"
          srcset={desktopScreenshot.src}
        />
        <img
          src={desktopScreenshot.src}
          alt={desktopScreenshot.alt}
          width={desktopScreenshot.width}
          height={desktopScreenshot.height}
          class="h-full w-full object-cover object-top"
          loading="lazy"
          decoding="async"
          sizes="(min-width: 768px) 50vw, 100vw"
        />
      </picture>
    ) : (
      <div class={`relative h-full overflow-hidden bg-gradient-to-br ${toneClasses[project.previewTone]}`}>
        <div class="flex items-center gap-1.5 border-b border-white/10 px-4 py-3" aria-hidden="true">
          <span class="h-2.5 w-2.5 rounded-full bg-white/30"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-white/10"></span>
          <span class={`ml-auto rounded-full border px-2 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] ${statusClasses[project.status]}`}>
            {project.status}
          </span>
        </div>

        <div class="flex h-full flex-col justify-between px-5 py-5 text-white">
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.26em] text-white/60">{project.typeLabel}</p>
            <h3 class="mt-3 max-w-[12ch] text-2xl font-semibold leading-tight">{project.title}</h3>
            <p class="mt-3 inline-flex rounded-full border border-white/10 bg-white/10 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/80">
              {project.previewLabel}
            </p>
            <p class="mt-2 max-w-xs text-sm leading-relaxed text-white/70">{project.previewNote}</p>
          </div>

          <div class="space-y-2" aria-hidden="true">
            {barClasses[project.previewTone].map((barClass, index) => (
              <div
                class={`h-2 rounded-full ${barClass}`}
                style={`width: ${84 - index * 12}%;`}
              ></div>
            ))}
          </div>
        </div>
      </div>
    )}
  </div>

  <div class="flex flex-1 flex-col p-6">
    <div class="flex flex-wrap gap-2">
      <span class="inline-flex rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-600">
        {project.typeLabel}
      </span>
      <span class={`inline-flex rounded-full border px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] ${statusClasses[project.status]}`}>
        {project.status}
      </span>
    </div>

    <h3 class="mt-4 text-xl font-semibold text-slate-900">
      <a
        href={`/work/${project.slug}`}
        class="hover:text-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
        aria-label={`View details for ${project.title}`}
      >
        {project.title}
      </a>
    </h3>
    <p class="mt-3 text-sm leading-relaxed text-slate-700">{project.summary}</p>

    <ul class="mt-4 space-y-2 text-sm leading-relaxed text-slate-700">
      {project.bullets.map((bullet) => (
        <li class="flex gap-2">
          <span class="mt-1 h-2 w-2 rounded-full bg-brand-500" aria-hidden="true"></span>
          <span>{bullet}</span>
        </li>
      ))}
    </ul>

    {showAudit && project.lighthouse && (
      <div class="mt-5">
        <TechnicalAudit project={project} />
      </div>
    )}

    <div class="mt-6 flex flex-wrap items-center gap-4">
      <a
        href={`/work/${project.slug}`}
        class="inline-flex items-center text-sm font-medium text-brand-700 underline decoration-brand-200 underline-offset-4 hover:text-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
      >
        View project page
      </a>
      <a
        href={project.href}
        class="inline-flex items-center text-sm font-medium text-slate-900 underline decoration-slate-300 underline-offset-4 hover:text-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
        aria-label={`${project.linkLabel}: ${project.title}`}
        target="_blank"
        rel="noopener noreferrer"
      >
        {project.linkLabel}
      </a>
    </div>
  </div>
</article>
