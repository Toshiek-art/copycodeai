---
import type { WorkProject } from '../../data/work';

interface Props {
  project: WorkProject;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const audit = project.lighthouse;
---

<div class={`rounded-xl border border-slate-200 bg-slate-50 ${compact ? 'p-3' : 'p-4'}`}>
  <div class={`flex ${compact ? 'flex-wrap items-center gap-2' : 'items-start gap-4'} `}>
    <div class="min-w-0 flex-1">
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-600">
        {audit.label}
      </p>
      <p class={`mt-2 font-medium text-slate-900 ${compact ? 'text-xs' : 'text-sm'}`}>
        Lighthouse score: <span class="whitespace-nowrap">{audit.scoreText}</span>
      </p>
      <p class={`mt-1 text-slate-600 ${compact ? 'text-[11px]' : 'text-xs'} leading-relaxed`}>
        Performance, accessibility, best practices, and SEO on the latest audited build.
      </p>
      <a
        href={audit.href}
        class={`mt-2 inline-flex items-center font-medium text-slate-800 underline decoration-slate-300 underline-offset-4 hover:text-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2 ${compact ? 'text-[11px]' : 'text-xs'}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Open Lighthouse audit for ${project.title}`}
      >
        View audit
      </a>
    </div>

    {!compact && (
      <a
        href={audit.href}
        class="hidden shrink-0 lg:block"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Open Lighthouse audit thumbnail for ${project.title}`}
      >
        <img
          src={audit.thumbnail.src}
          alt={audit.thumbnail.alt}
          width={audit.thumbnail.width}
          height={audit.thumbnail.height}
          class="h-28 w-16 rounded-lg border border-slate-200 object-cover object-top shadow-sm"
          loading="lazy"
          decoding="async"
        />
      </a>
    )}
  </div>
</div>
