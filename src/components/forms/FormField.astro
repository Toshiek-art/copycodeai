---
interface Props {
  name: string;
  label: string;
  type?: string;
  as?: 'input' | 'textarea';
  value?: string;
  placeholder?: string;
  autocomplete?: string;
  required?: boolean;
  hint?: string;
  error?: string;
  rows?: number;
  class?: string;
}

const {
  name,
  label,
  type = 'text',
  as = 'input',
  value,
  placeholder,
  autocomplete,
  required = false,
  hint,
  error,
  rows = 4,
  class: className = '',
  ...rest
} = Astro.props;

const inputId = `field-${name}`;
const describedByIds = [hint ? `${inputId}-hint` : null, error ? `${inputId}-error` : null].filter(Boolean).join(' ') || undefined;
---

<div class={`space-y-2 ${className}`.trim()} {...rest}>
  <label for={inputId} class="block text-sm font-medium text-slate-900">
    {label}
    {required && <span class="ml-1 text-brand-700" aria-hidden="true">*</span>}
  </label>

  {as === 'textarea' ? (
    <textarea
      id={inputId}
      name={name}
      placeholder={placeholder}
      autocomplete={autocomplete}
      required={required}
      rows={rows}
      aria-invalid={error ? 'true' : 'false'}
      aria-describedby={describedByIds}
      class={`block w-full rounded-xl border px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-100 ${
        error ? 'border-red-400' : 'border-slate-300'
      }`.trim()}
    >
      {value}
    </textarea>
  ) : (
    <input
      id={inputId}
      name={name}
      type={type}
      value={value}
      placeholder={placeholder}
      autocomplete={autocomplete}
      required={required}
      aria-invalid={error ? 'true' : 'false'}
      aria-describedby={describedByIds}
      class={`block w-full rounded-xl border px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-100 ${
        error ? 'border-red-400' : 'border-slate-300'
      }`.trim()}
    />
  )}

  {hint && (
    <p id={`${inputId}-hint`} class="text-sm leading-6 text-slate-600">
      {hint}
    </p>
  )}

  {error && (
    <p id={`${inputId}-error`} class="text-sm font-medium text-red-700">
      {error}
    </p>
  )}
</div>

