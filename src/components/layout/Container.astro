---
interface Props {
  size?: 'narrow' | 'content' | 'wide' | 'full';
  class?: string;
}

const { size = 'wide', class: className = '', ...rest } = Astro.props;

const sizeClasses = {
  narrow: 'max-w-3xl',
  content: 'max-w-5xl',
  wide: 'max-w-7xl',
  full: 'max-w-none'
} as const;
---

<div class={`mx-auto w-full ${sizeClasses[size]} px-6 sm:px-8 lg:px-10 xl:px-12 ${className}`.trim()} {...rest}>
  <slot />
</div>
