---
interface Props {
  titleId: string;
  eyebrowDefault: string;
  eyebrowRenew: string;
  titleDefault: string;
  titleRenew: string;
  bodyDefault: string;
  bodyRenew: string;
  submitRenew?: string;
}

const {
  titleId,
  eyebrowDefault,
  eyebrowRenew,
  titleDefault,
  titleRenew,
  bodyDefault,
  bodyRenew,
  submitRenew = 'Request a fresh access link'
} = Astro.props;
---

<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8" data-guide-request-panel data-request-state="default" data-renew-submit-copy={submitRenew}>
  <p
    class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700"
    data-guide-request-eyebrow
    data-default-copy={eyebrowDefault}
    data-renew-copy={eyebrowRenew}
  >
    {eyebrowDefault}
  </p>
  <h2
    id={titleId}
    class="mt-2 text-3xl font-semibold text-ink-900"
    data-guide-request-title
    data-default-copy={titleDefault}
    data-renew-copy={titleRenew}
  >
    {titleDefault}
  </h2>
  <p
    class="mt-3 max-w-3xl text-base leading-7 text-slate-700"
    data-guide-request-body
    data-default-copy={bodyDefault}
    data-renew-copy={bodyRenew}
  >
    {bodyDefault}
  </p>
  <slot />
</div>

<script is:inline>
  (() => {
    const renew = new URLSearchParams(window.location.search).get('renew') === '1';

    if (!renew) {
      return;
    }

    document.querySelectorAll('[data-guide-request-panel]').forEach((panel) => {
      const eyebrow = panel.querySelector('[data-guide-request-eyebrow]');
      const title = panel.querySelector('[data-guide-request-title]');
      const body = panel.querySelector('[data-guide-request-body]');
      const renewInput = panel.querySelector('input[name="renew"]');
      const submitButton = panel.querySelector('[data-guide-request-submit]');

      if (eyebrow) {
        eyebrow.textContent = eyebrow.getAttribute('data-renew-copy') || eyebrow.textContent || '';
      }

      if (title) {
        title.textContent = title.getAttribute('data-renew-copy') || title.textContent || '';
      }

      if (body) {
        body.textContent = body.getAttribute('data-renew-copy') || body.textContent || '';
      }

      if (renewInput) {
        renewInput.value = '1';
      }

      if (submitButton) {
        submitButton.textContent = panel.getAttribute('data-renew-submit-copy') || submitButton.textContent || '';
      }

      panel.setAttribute('data-request-state', 'renew');
    });
  })();
</script>
