---
interface Props {
  category: string;
  title: string;
  description: string;
  href: string;
  label?: string;
  class?: string;
}

const {
  category,
  title,
  description,
  href,
  label = 'Read guide',
  class: className = '',
  ...rest
} = Astro.props;
---

<article
  class={`flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-soft ${className}`.trim()}
  {...rest}
>
  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-600">{category}</p>
  <h3 class="mt-3 text-2xl font-semibold text-ink-900">{title}</h3>
  <p class="mt-3 flex-1 text-sm leading-6 text-slate-700">{description}</p>
  <a
    href={href}
    class="mt-5 inline-flex items-center text-sm font-semibold text-brand-700 hover:text-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
  >
    {label}
  </a>
</article>
