---
interface Props {
  label: string;
  href: string;
  title?: string;
  class?: string;
}

const {
  label,
  href,
  title = 'Related service',
  class: className = '',
  ...rest
} = Astro.props;
---

<aside
  class={`rounded-2xl border border-slate-200 bg-white p-6 shadow-soft ${className}`.trim()}
  {...rest}
>
  <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-600">{title}</p>
  <a
    href={href}
    class="mt-3 inline-flex text-lg font-semibold text-ink-900 hover:text-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
  >
    {label}
  </a>
  <p class="mt-2 text-sm leading-6 text-slate-600">A relevant next step for teams that want to move from reading to implementation.</p>
</aside>
