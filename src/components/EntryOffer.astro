---
import Section from './layout/Section.astro';
import Container from './layout/Container.astro';
import CTAGroup from './layout/CTAGroup.astro';

const schedulingLink = 'https://calendly.com/aldogustavomalasomma/15min';
const briefHref = '/contact#structured-request';
---

<Section id="blueprint" aria-labelledby="entry-offer-title">
  <Container size="wide">
    <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8 lg:p-10">
    <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">Entry Offer</p>
    <p class="mb-2 mt-2 text-lg font-medium text-slate-600">A lower-friction start when you need launch clarity without overbuilding.</p>
    <h2 id="entry-offer-title" class="mt-2 text-3xl font-semibold text-ink-900">Compliance-Ready Landing Page</h2>
    <p class="mt-3 text-xl font-semibold text-slate-900">From €750</p>
    <p class="mt-1 text-sm text-slate-600">Typical delivery: 3-5 days</p>
    <p class="mt-2 max-w-3xl text-slate-700">
      A landing page or MVP-style site for startups and digital businesses that need to launch fast without avoidable GDPR or accessibility issues.
    </p>

    <ul class="mt-5 space-y-2 text-sm leading-relaxed text-slate-700">
      <li class="flex gap-2"><span class="mt-1 h-2 w-2 rounded-full bg-brand-500" aria-hidden="true"></span><span>Launch-ready landing or MVP structure</span></li>
      <li class="flex gap-2"><span class="mt-1 h-2 w-2 rounded-full bg-brand-500" aria-hidden="true"></span><span>GDPR-aware form and data-flow structure</span></li>
      <li class="flex gap-2"><span class="mt-1 h-2 w-2 rounded-full bg-brand-500" aria-hidden="true"></span><span>EAA/WCAG-aware UX foundations</span></li>
      <li class="flex gap-2"><span class="mt-1 h-2 w-2 rounded-full bg-brand-500" aria-hidden="true"></span><span>Implementation notes you can use right away</span></li>
      <li class="flex gap-2"><span class="mt-1 h-2 w-2 rounded-full bg-brand-500" aria-hidden="true"></span><span>Fixed scope and clear handoff</span></li>
    </ul>

    <CTAGroup>
      <a
        href={schedulingLink}
        class="inline-flex items-center justify-center rounded-xl bg-brand-700 px-6 py-3 text-sm font-semibold text-white shadow-soft hover:bg-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
      >
        Start with a 15-min Technical Assessment
      </a>
      <a
        href={briefHref}
        class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 hover:border-slate-400 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
      >
        Request a Brief Review
      </a>
    </CTAGroup>
    <p class="mt-2 text-xs font-normal text-slate-600">Fixed price. Short delivery window. Written follow-up included.</p>
    </article>

    <section class="mt-5 rounded-2xl border border-slate-200 bg-white p-5 shadow-soft lg:p-6" aria-labelledby="after-call-title">
    <h3 id="after-call-title" class="text-sm font-semibold uppercase tracking-wide text-slate-700">What happens after the call</h3>
    <p class="mt-2 text-sm text-slate-600">Short call. Clear next steps. No vague follow-up.</p>
    <ol class="mt-3 grid gap-3 text-sm text-slate-700 md:grid-cols-3">
      <li class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">15-min technical assessment</li>
      <li class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">You receive a written summary with the main risks, priorities, and next steps</li>
      <li class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">If there’s a fit, the right next offer is scoped separately</li>
    </ol>
    </section>
  </Container>
</Section>
